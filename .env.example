# DopaFlow Environment Configuration
# Copy this file to .env for local development.
# For production, use docker-compose.env or set vars in your deployment platform.
#
# Do not commit real secrets. Use CI/provider secret storage for release builds.

# === Database ===
DOPAFLOW_DB_PATH=/data/dopaflow.db

# === Turso (optional — leave empty for local SQLite) ===
# DOPAFLOW_TURSO_URL=        # Turso primary DB URL (wss://db-name.turso.io)
# DOPAFLOW_TURSO_TOKEN=      # Auth token from Turso dashboard
# DOPAFLOW_TURSO_REPLICA_URL=  # Read replica URL (optional — enables horizontal read scaling)

# === Auth ===
# Set DOPAFLOW_AUTH_TOKEN_SECRET to a long random string (32+ chars) in production.
# Set DOPAFLOW_API_KEY to a strong random string for API key auth.
DOPAFLOW_ENFORCE_AUTH=false
DOPAFLOW_DEV_AUTH=false
# DOPAFLOW_API_KEY=
# DOPAFLOW_AUTH_TOKEN_SECRET=
DOPAFLOW_AUTH_TOKEN_ISSUER=dopaflow

# === OAuth (optional) ===
# Get these from Google Cloud Console -> APIs & Services -> Credentials
# DOPAFLOW_GOOGLE_CLIENT_ID=
# DOPAFLOW_GOOGLE_CLIENT_SECRET=
# DOPAFLOW_ENABLE_OAUTH=false

# === External OIDC Provider (optional — SSO via Keycloak, Zitadel, etc.) ===
# Configure these to enable "Sign in with SSO" on the login page.
# DOPAFLOW_OIDC_PROVIDER_NAME=keycloak
# DOPAFLOW_OIDC_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# DOPAFLOW_OIDC_CLIENT_ID=dopaflow
# DOPAFLOW_OIDC_CLIENT_SECRET=
# DOPAFLOW_OIDC_SCOPES=openid profile email
# DOPAFLOW_OIDC_DEFAULT_ROLE=viewer

# === URLs ===
DOPAFLOW_BASE_URL=http://localhost:8000

# === Security (set to true for production) ===
DOPAFLOW_ALLOW_LOCAL_WEBHOOK_TARGETS=false
DOPAFLOW_DISABLE_LOCAL_AUDIO=false

# === Background Jobs ===
DOPAFLOW_DISABLE_BACKGROUND_JOBS=false

# === Backup ===
DOPAFLOW_JOURNAL_BACKUP_DIR=/data/backups

# Optional: additional browser origins for self-hosted/PWA deployments
# DOPAFLOW_EXTRA_CORS_ORIGINS=https://your-domain.com
