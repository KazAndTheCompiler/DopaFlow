# DopaFlow Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite (local development)
DOPAFLOW_DB_PATH=/home/user/.local/share/DopaFlow/db.sqlite

# Turso/libSQL (production/cloud)
# DOPAFLOW_TURSO_URL=libsql://your-db.turso.io
# DOPAFLOW_TURSO_TOKEN=your-turso-auth-token
# DOPAFLOW_TURSO_REPLICA_URL=libsql://your-replica.turso.io

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Configuration (REQUIRED for production)
DOPAFLOW_AUTH_TOKEN_SECRET=your-super-secret-jwt-key-min-32-chars
DOPAFLOW_AUTH_TOKEN_ISSUER=dopaflow

# API Key for service-to-service communication
DOPAFLOW_API_KEY=your-api-key-for-integrations

# Operations Secret (for admin endpoints)
DOPAFLOW_OPS_SECRET=your-ops-secret-key

# OAuth Configuration (optional)
DOPAFLOW_ENABLE_OAUTH=false
DOPAFLOW_GOOGLE_CLIENT_ID=your-google-client-id
DOPAFLOW_GOOGLE_CLIENT_SECRET=your-google-client-secret
DOPAFLOW_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v2/calendar/auth/callback

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# ⚠️ NEVER enable in production!
DOPAFLOW_DEV_AUTH=false
DOPAFLOW_ENFORCE_AUTH=false

# Disable features for testing
DOPAFLOW_DISABLE_LOCAL_AUDIO=false
DOPAFLOW_DISABLE_BACKGROUND_JOBS=false

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Base URL for the application
DOPAFLOW_BASE_URL=http://127.0.0.1:8000

# Production flag (enables security checks)
DOPAFLOW_PRODUCTION=false

# Packaged mode (for desktop app)
DOPAFLOW_PACKAGED=false

# CORS origins (comma-separated for multiple)
DOPAFLOW_EXTRA_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# BACKUP & STORAGE
# =============================================================================

# Journal backup directory
DOPAFLOW_JOURNAL_BACKUP_DIR=/home/user/.local/share/DopaFlow/journal-backup

# =============================================================================
# RATE LIMITING (Production)
# =============================================================================

# Default API rate limit (requests per minute)
RATE_LIMIT_DEFAULT=60

# Authenticated user rate limit
RATE_LIMIT_AUTHENTICATED=120

# Command endpoints limit (higher cost operations)
RATE_LIMIT_COMMANDS=30

# Packy AI assistant limit
RATE_LIMIT_PACKY=20

# Health check endpoints limit
RATE_LIMIT_HEALTH=300

# =============================================================================
# DATABASE CONNECTION POOL (Production)
# =============================================================================

# Minimum connections in pool
DOPAFLOW_DB_POOL_MIN=2

# Maximum connections in pool
DOPAFLOW_DB_POOL_MAX=10

# Connection timeout in seconds
DOPAFLOW_DB_TIMEOUT=30.0

# =============================================================================
# HEALTH CHECK ALERTING (Production)
# =============================================================================

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=60

# Alert cooldown between same alerts (seconds)
ALERT_COOLDOWN_SECONDS=300

# Consecutive failures before alerting
CONSECUTIVE_FAILURES_THRESHOLD=2

# Slack webhook URL for alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty integration key
# PAGERDUTY_INTEGRATION_KEY=your-pagerduty-key

# Custom webhook URL for alerts
# HEALTH_ALERT_WEBHOOK_URL=https://your-monitoring.com/webhook

# Environment name (for alert tagging)
ENVIRONMENT=production

# Service name (for alert tagging)
SERVICE_NAME=dopaflow

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================

# Sentry for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# NOTES
# =============================================================================

# Required for production:
# - DOPAFLOW_AUTH_TOKEN_SECRET (min 32 characters)
# - DOPAFLOW_PRODUCTION=true
# - DOPAFLOW_ENFORCE_AUTH=true
# - DOPAFLOW_DEV_AUTH=false

# Database priority:
# 1. If TURSO_URL is set, uses Turso/libSQL
# 2. Otherwise uses local SQLite at DB_PATH

# For OAuth calendar integration:
# 1. Set ENABLE_OAUTH=true
# 2. Configure Google OAuth credentials
# 3. Set redirect URI in Google Console
