# DopaFlow Environment Configuration
# Copy this file to .env and fill in your values

# Optional: Turso cloud database (leave empty to use local SQLite)
DOPAFLOW_TURSO_URL=
DOPAFLOW_TURSO_AUTH_TOKEN=

# Optional: Google Calendar OAuth
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend settings
DOPAFLOW_SECRET_KEY=change-me-to-something-random
DOPAFLOW_CORS_ORIGINS=http://localhost:5173
