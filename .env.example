# DopaFlow Environment Configuration
# Copy this file to .env for local development.
#
# Do not commit real secrets. Use CI/provider secret storage for release builds.

# Optional: Turso cloud database (leave empty to use local SQLite)
DOPAFLOW_TURSO_URL=
DOPAFLOW_TURSO_TOKEN=

# Optional: Google Calendar OAuth
# Get these from Google Cloud Console -> APIs & Services -> Credentials
DOPAFLOW_GOOGLE_CLIENT_ID=
DOPAFLOW_GOOGLE_CLIENT_SECRET=

# Optional: signed bearer-token support for remote scoped API access.
# Set this to a long random string before enabling remote token issuance.
DOPAFLOW_AUTH_TOKEN_SECRET=

# Optional: remote API-key protection.
# If you set DOPAFLOW_ENFORCE_AUTH=true, set a real DOPAFLOW_API_KEY too.
DOPAFLOW_API_KEY=

# Backend auth posture
# Leave these false for normal desktop dev. Packaged builds should not force dev auth.
DOPAFLOW_ENFORCE_AUTH=false
DOPAFLOW_TRUST_LOCAL_CLIENTS=false

# Optional: additional browser origins for self-hosted/PWA deployments
DOPAFLOW_EXTRA_CORS_ORIGINS=
