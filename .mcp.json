{
  "mcpServers": {
    "dopaflow-node": {
      "command": "python3",
      "args": [
        "${DOPAFLOW_TOOLS_DIR:-./tools}/mcp/node-tooling-bridge/server.py"
      ],
      "env": {
        "DOPAFLOW_NODE_BIN": "${DOPAFLOW_NODE_BIN:-.codex-bin}",
        "DOPAFLOW_FRONTEND_DIR": "${DOPAFLOW_FRONTEND_DIR:-./frontend}"
      }
    }
  }
}