{
  "name": "dopaflow-desktop",
  "version": "2.0.7",
  "description": "DopaFlow — unified productivity for ADHD brains",
  "author": {
    "name": "KazAndTheCompiler",
    "url": "https://github.com/KazAndTheCompiler"
  },
  "private": true,
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "dist": "node scripts/build-desktop.js dev",
    "dist:mac": "node scripts/build-desktop.js dev --mac",
    "dist:win": "node scripts/build-desktop.js dev --win",
    "dist:linux": "node scripts/build-desktop.js dev --linux",
    "dist:all": "node scripts/build-desktop.js dev -mwl",
    "dist:stable": "node scripts/build-desktop.js stable",
    "dist:stable:mac": "node scripts/build-desktop.js stable --mac",
    "dist:stable:win": "node scripts/build-desktop.js stable --win",
    "dist:stable:linux": "node scripts/build-desktop.js stable --linux",
    "dist:stable:all": "node scripts/build-desktop.js stable -mwl"
  },
  "build": {
    "appId": "com.dopaflow.app",
    "afterPack": "./afterPack.js",
    "productName": "DopaFlow",
    "artifactName": "${productName}-${version}.${ext}",
    "extraMetadata": {
      "dopaflowReleaseChannel": "${env.DOPAFLOW_RELEASE_CHANNEL}"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "backend-runtime.js",
      "preload.js",
      "assets/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/dist/dopaflow-backend",
        "to": "dopaflow-backend",
        "filter": ["**/*"]
      },
      {
        "from": "../shared/version.json",
        "to": "dopaflow-backend/shared/version.json"
      }
    ],
    "linux": {
      "executableName": "dopaflow-desktop",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Office"
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-auto-launch": "^5.0.6",
    "electron-updater": "^6.3.9"
  }
}
