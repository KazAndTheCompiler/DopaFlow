{
  "name": "dopaflow-desktop",
  "version": "2.0.12",
  "description": "DopaFlow — unified productivity for ADHD brains",
  "author": {
    "name": "KazAndTheCompiler",
    "url": "https://github.com/KazAndTheCompiler"
  },
  "private": true,
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "test": "node --test tests/backend-runtime.test.js tests/main.test.js tests/runtime-auth.test.js tests/window-runtime.test.js",
    "dist": "node scripts/build-desktop.js dev",
    "dist:mac": "node scripts/build-desktop.js dev --mac",
    "dist:win": "node scripts/build-desktop.js dev --win",
    "dist:linux": "node scripts/build-desktop.js dev --linux",
    "dist:all": "node scripts/build-desktop.js dev -mwl",
    "dist:stable": "node scripts/build-desktop.js stable",
    "dist:stable:mac": "node scripts/build-desktop.js stable --mac",
    "dist:stable:win": "node scripts/build-desktop.js stable --win",
    "dist:stable:linux": "node scripts/build-desktop.js stable --linux",
    "dist:stable:all": "node scripts/build-desktop.js stable -mwl"
  },
  "build": {
    "appId": "com.dopaflow.app",
    "afterPack": "./afterPack.js",
    "productName": "DopaFlow",
    "artifactName": "${productName}-${version}.${ext}",
    "icon": "assets/icon.png",
    "extraMetadata": {
      "dopaflowReleaseChannel": "${env.DOPAFLOW_RELEASE_CHANNEL}"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "ipc-validation.js",
      "backend-runtime.js",
      "notification-runtime.js",
      "window-runtime.js",
      "runtime-auth.js",
      "preload.js",
      "assets/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/dist/dopaflow-backend",
        "to": "dopaflow-backend",
        "filter": ["**/*"]
      },
      {
        "from": "../shared/version.json",
        "to": "dopaflow-backend/shared/version.json"
      }
    ],
    "linux": {
      "icon": "assets/icon.png",
      "executableName": "dopaflow-desktop",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "${env.DOPAFLOW_GITHUB_OWNER}",
        "repo": "${env.DOPAFLOW_GITHUB_REPO}"
      }
    ]
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "electron-auto-launch": "^5.0.6",
    "electron-updater": "^6.3.9"
  }
}
