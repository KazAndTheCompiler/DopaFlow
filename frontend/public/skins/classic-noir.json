{
  "id": "classic-noir",
  "author": "ZoesTM",
  "version": "1.0.0",
  "name": "Classic Noir",
  "category": "dark",
  "preview": {
    "bg": "#0a0a0a",
    "accent": "#d4af37",
    "surface": "#141414"
  },
  "vars": {
    "--bg-app": "#0a0a0a",
    "--surface": "#141414",
    "--surface-2": "#1e1e1e",
    "--border": "#2a2a2a",
    "--text": "#f5f5f5",
    "--text-muted": "#888888",
    "--accent": "#d4af37",
    "--accent-soft": "#2a2520",
    "--shadow-soft": "0 20px 50px rgba(0, 0, 0, 0.5)",
    "--timeline-now": "#d4af37",
    "--calendar-grid-line": "#2a2a2a",
    "--day-today-ring": "#d4af37",
    "--event-default": "#c9a227",
    "--task-default": "#b8a030",
    "--reminder-default": "#e6c65c",
    "--busy-block-hint": "rgba(212, 175, 55, 0.12)",
    "--free-slot-hint": "rgba(136, 136, 136, 0.08)",
    "--selected-range": "rgba(212, 175, 55, 0.12)",
    "--state-completed": "#4caf50",
    "--state-ok": "#4caf50",
    "--state-warn": "#d4af37",
    "--state-overdue": "#ef5350",
    "--state-conflict": "#ab47bc",
    "--state-readonly": "#4a4a4a",
    "--state-drag-active": "#d4af37",
    "--state-drop-target": "#2a2520",
    "--text-primary": "var(--text)",
    "--text-secondary": "var(--text-muted)",
    "--text-disabled": "#3a3a3a",
    "--text-inverted": "#000000",
    "--text-link": "#f0d060",
    "--border-subtle": "var(--border)",
    "--border-strong": "#3a3a3a",
    "--focus-ring": "rgba(212, 175, 55, 0.3)",
    "--shadow-elevated": "0 24px 56px rgba(0, 0, 0, 0.55)",
    "--shadow-floating": "0 32px 72px rgba(0, 0, 0, 0.6)"
  }
}