{
  "id": "amber-terminal",
  "author": "ZoesTM",
  "version": "1.0.0",
  "name": "Amber Terminal",
  "category": "dark",
  "preview": {
    "bg": "#1b140c",
    "accent": "#ffb000",
    "surface": "#251c11"
  },
  "vars": {
    "--bg-app": "#1b140c",
    "--surface": "#251c11",
    "--surface-2": "#312515",
    "--border": "#785a22",
    "--text": "#ffd888",
    "--text-muted": "#d0aa57",
    "--accent": "#ffb000",
    "--accent-soft": "#5d3d06",
    "--shadow-soft": "0 2px 12px rgba(0,0,0,0.28), 0 1px 3px rgba(0,0,0,0.18)",
    "--shadow-elevated": "0 8px 28px rgba(0,0,0,0.36), 0 2px 8px rgba(0,0,0,0.22)",
    "--shadow-floating": "0 20px 52px rgba(0,0,0,0.46), 0 4px 14px rgba(0,0,0,0.28)",
    "--state-completed": "#78c679",
    "--state-ok": "#78c679",
    "--state-warn": "#e8a020",
    "--state-overdue": "#ff7a00",
    "--state-conflict": "#ff4d6d",
    "--state-readonly": "#a58147",
    "--state-drag-active": "#ffb000",
    "--state-drop-target": "#5d3d06",
    "--text-primary": "#ffd888",
    "--text-secondary": "#d0aa57",
    "--text-disabled": "#8f723a",
    "--text-inverted": "#120d06",
    "--text-link": "#ffcf5a",
    "--border-subtle": "#785a22",
    "--border-strong": "#b9892f",
    "--focus-ring": "rgba(255,176,0,0.32)",
    "--timeline-now": "#ffb000",
    "--calendar-grid-line": "#785a22",
    "--day-today-ring": "#ffb000",
    "--event-default": "#ffbf47",
    "--task-default": "#ffd888",
    "--reminder-default": "#ff7a00",
    "--busy-block-hint": "rgba(255,176,0,0.16)",
    "--free-slot-hint": "rgba(208,170,87,0.12)",
    "--selected-range": "rgba(255,176,0,0.18)",
    "--surface-glass-blur": "blur(14px)",
    "--surface-inner-light": "linear-gradient(135deg, rgba(255,176,0,0.06) 0%, transparent 60%)",
    "--surface-inner-highlight": "rgba(255,176,0,0.03)",
    "--surface-specular": "radial-gradient(ellipse at 30% 20%, rgba(255,176,0,0.04) 0%, transparent 50%)",
    "--surface-edge-light": "1px solid rgba(255,176,0,0.1)",
    "--surface-3": "rgba(255,176,0,0.04)"
  }
}